// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum UserRole {
  RIDER
  DRIVER
  CAR_OWNER
  ADMIN
}

enum VehicleType {
  SEDAN
  SUV
  MINIVAN_XL
  LUXURY
  ELECTRIC_HYBRID
}

model User {
  id             String   @id @default(uuid())
  email          String?  @unique
  phone          String?  @unique
  firstName      String
  lastName       String
  password       String?
  provider       String? // "local" | "google" | "facebook"
  providerId     String?  @unique
  verified       Boolean  @default(false)
  role           UserRole @default(RIDER)
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  fcmToken       String?

  language             String? @default("en") // e.g. "en", "fr", "yo"
  pushNotifications    Boolean @default(true)
  navigationPreference String? @default("google") // e.g. "google", "waze", "apple"

  refreshTokens     RefreshToken[]
  verificationCodes VerificationCode[]

  driver         Driver?
  rider          Rider?
  carOwner       CarOwner?
  scheduledRides ScheduledRide[] @relation("RiderScheduledRides")
  trips          Trip[]
  notifications  Notification[]
  wallet         Wallet?

  @@map("users")
}

model Driver {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankName      String?
  accountNumber String?
  accountName   String?

  vehicleType  VehicleType?
  vehicleModel String?
  vehiclePlate String?      @unique
  vehicleColor String?
  vehicleYear  Int?

  licenseUrls         String[] // array of S3 URLs
  governmentIdUrls    String[] // NIN / Government ID
  vehicleDocumentUrls String[] // Vehicle documents (multiple)

  licenseNumber     String?   @unique
  licenseExpiry     DateTime?
  licenseUrl        String? // S3 URL
  vehicleRegUrl     String? // S3 URL
  insuranceUrl      String? // S3 URL
  documentsVerified Boolean   @default(false)

  status           String    @default("pending") // pending, approved, rejected, suspended
  rejectionReason  String?
  approvedAt       DateTime?
  suspendedAt      DateTime?
  suspensionReason String?

  rating        Float @default(0.0)
  totalTrips    Int   @default(0)
  totalEarnings Float @default(0.0)

  isOnline           Boolean   @default(false)
  currentLocation    Json?
  lastLocationUpdate DateTime? @db.Timestamp

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scheduledRides ScheduledRide[]
  trips          Trip[]

  vehicleFeatures    String[]  @default([]) // e.g. ["navigation", "air-conditioning"]
  vehiclePhotos      String[]  @default([]) // S3 URLs for front, back, interior, etc.
  insuranceExpiry    DateTime?
  registrationExpiry DateTime?
  inspectionExpiry   DateTime?

  carRentalBookings CarRentalBooking[]

  courier         Courier?
  courierPayouts  CourierPayout[]
  courierDisputes CourierDispute[]
  courierAlerts   CourierAlert[]

  @@map("drivers")
}

model CarRental {
  id      String   @id @default(uuid())
  ownerId String
  owner   CarOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  vehicleModel String
  vehiclePlate String   @unique
  vehicleColor String?
  vehicleYear  Int?
  vehicleType  String
  pricePerDay  Float
  available    Boolean  @default(true)
  description  String?
  images       String[]

  status                 String   @default("pending") // pending, under_review, approved, rejected
  verificationPercentage Int?     @default(0)
  submittedAt            DateTime @default(now())

  registrationUrl String?
  insuranceUrl    String?
  licenseUrl      String?
  inspectionUrl   String?

  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings CarRentalBooking[]

  @@map("car_rentals")
}

model CarRentalBooking {
  id       String @id @default(uuid())
  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  carId String
  car   CarRental @relation(fields: [carId], references: [id], onDelete: Cascade)

  startDate  DateTime
  endDate    DateTime
  totalPrice Float?
  status     String   @default("pending") // pending, confirmed, active, completed, cancelled

  returnNotes      String?
  adjustmentReason String?

  disputes Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("car_rental_bookings")
}

model Dispute {
  id        String @id @default(uuid())
  disputeId String @unique @default("RD")

  rentalBookingId String
  rentalBooking   CarRentalBooking @relation(fields: [rentalBookingId], references: [id], onDelete: Cascade)

  type        String
  severity    String
  status      String @default("Open")
  description String

  renterNotes  String?
  ownerNotes   String?
  evidenceUrls String[]

  resolutionAction String?
  resolutionNotes  String?
  resolvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("disputes")
}

model Rider {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalRides Int   @default(0)
  rating     Float @default(0.0)
  totalSpent Float @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("riders")
}

model CarOwner {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String?
  status          String    @default("pending")
  approvedAt      DateTime?
  rejectionReason String?

  totalCars     Int   @default(0)
  totalEarnings Float @default(0.0)

  carRentals CarRental[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("car_owners")
}

model VehicleCategory {
  id             String  @id @default(uuid())
  name           String  @unique
  description    String?
  commissionRate Float   @default(15)

  dailyMinRate   Float
  dailyMaxRate   Float
  weeklyMinRate  Float?
  weeklyMaxRate  Float?
  monthlyMinRate Float?
  monthlyMaxRate Float?

  status Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicle_categories")
}

model ScheduledRide {
  id      String @id @default(uuid())
  riderId String
  rider   User   @relation("RiderScheduledRides", fields: [riderId], references: [id])

  pickupLocation  Json
  dropoffLocation Json
  scheduledTime   DateTime
  vehicleType     String?
  estimatedPrice  Float?
  status          String   @default("pending")
  driverId        String?
  driver          Driver?  @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scheduled_rides")
}

model Trip {
  id              String    @id @default(uuid())
  riderId         String
  driverId        String?
  pickupLocation  Json // { lat: number, lng: number, address?: string }
  dropoffLocation Json // { lat: number, lng: number, address?: string }
  estimatedFare   Float?
  actualFare      Float?
  currency        String    @default("NGN")
  country         String?
  status          String    @default("REQUESTED") // REQUESTED, SEARCHING_DRIVER, DRIVER_ASSIGNED, DRIVER_ARRIVED, IN_PROGRESS, COMPLETED, CANCELLED
  rideType        String    @default("REGULAR") // REGULAR, STANDARD, PREMIUM
  surgeMultiplier Float?    @default(1.0)
  startTime       DateTime?
  endTime         DateTime?
  revenue         Float?
  rating          Float?

  paymentMethod    String? // "CASH" | "CARD" | "WALLET"
  paymentStatus    String  @default("PENDING") // PENDING, PAID, FAILED
  commissionAmount Float?
  promoCode        String?
  riderRating      Float?
  riderFeedback    String?

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rider        User          @relation(fields: [riderId], references: [id])
  driver       Driver?       @relation(fields: [driverId], references: [id])
  conversation Conversation?

  @@map("trips")
}

model Wallet {
  id      String @id @default(uuid())
  balance Float  @default(0)
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model Payment {
  id     String @id @default(uuid())
  tripId String @unique
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  amount         Float
  currency       String    @default("NGN")
  method         String // CASH, CARD, WALLET
  status         String    @default("PENDING")
  transactionRef String? // Paystack reference
  paidAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model City {
  id           String   @id @default(uuid())
  name         String
  state        String
  country      String   @default("Nigeria")
  latitude     Float
  longitude    Float
  serviceZones String[]
  isActive     Boolean  @default(true)
  pricingLevel String   @default("STANDARD") // BUDGET, STANDARD, PREMIUM

  hubs Hub[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cities")
}

model Hub {
  id              String  @id @default(uuid())
  name            String
  address         String
  cityId          String
  city            City    @relation(fields: [cityId], references: [id])
  latitude        Float
  longitude       Float
  capacity        Int
  operatingHours  String  @default("24/7")
  assignedDrivers Int     @default(0)
  isActive        Boolean @default(true)

  zonesCovered       String[] @default([])
  pricingTier        String   @default("STANDARD") // BUDGET, STANDARD, PREMIUM
  baseAdjustment     Float    @default(0)
  distanceMultiplier Float    @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hubs")
}

model Courier {
  id       String @id @default(uuid())
  driverId String @unique
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  vehicleType String // "Bike", "Car"
  status      String @default("Offline") // Online, Offline, On Delivery, Suspended

  rating          Float @default(0.0)
  totalDeliveries Int   @default(0)
  successRate     Float @default(0.0)

  isActive Boolean @default(true)

  deliveries Delivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("couriers")
}

model Delivery {
  id             String @id @default(uuid())
  trackingNumber String @unique

  courierId String
  courier   Courier @relation(fields: [courierId], references: [id], onDelete: Cascade)

  pickupLocation  Json
  dropoffLocation Json
  fare            Float?

  status String @default("In Transit") // In Transit, Delivered, Failed, Cancelled

  category String // Food & Beverages, Electronics, Documents, Groceries, Fragile Items, Retail Goods, Medical Supplies

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("deliveries")
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    String? // e.g. "ride_request", "payment", "system"
  read    Boolean @default(false)
  data    Json? // optional payload, e.g. { rideId: "..." }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      String // "signup" | "reset-password"
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_codes")
}

model CourierSurcharge {
  id          String  @id @default(uuid())
  size        String  @unique // SMALL, MEDIUM, LARGE, EXTRA_LARGE
  weightRange String
  bikeExtra   Float?
  carExtra    Float?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courier_surcharges")
}

model CourierPayout {
  id       String @id @default(uuid())
  driverId String
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  rideEarnings     Float
  deliveryEarnings Float
  bonus            Float  @default(0)
  commission       Float
  pendingAmount    Float
  status           String @default("PENDING") // PENDING, APPROVED, ON_HOLD, PAID

  approvedAt DateTime?
  paidAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courier_payouts")
}

model CourierPricing {
  id             String  @id @default(uuid())
  category       String  @unique // e.g. "BIKE STANDARD", "CAR EXPRESS", "CAR XL"
  baseFare       Float
  ratePerKm      Float
  minFare        Float
  peakMultiplier Float   @default(1.0)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courier_pricing")
}

model GeographicZone {
  id         String  @id @default(uuid())
  name       String
  type       String // "URBAN", "SUBURBAN", "RURAL", "INTERCITY"
  multiplier Float   @default(1.0)
  ratePerKm  Float
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("geographic_zones")
}

model CourierCategory {
  id                 String   @id @default(uuid())
  name               String   @unique
  description        String?
  vehicleRestriction String? // "BIKE ONLY", "CAR ONLY", "BOTH"
  insuranceLevel     String? // "NONE", "BASIC", "STANDARD", "PREMIUM"
  pricingMultiplier  Float    @default(1.0)
  maxDeliveryWindow  Int? // in minutes
  requirements       String[] @default([])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courier_categories")
}

model CourierDispute {
  id          String @id @default(uuid())
  disputeCode String @unique // DSP-001

  trackingNumber String?
  driverId       String?
  driver         Driver? @relation(fields: [driverId], references: [id])

  status   String @default("OPEN") // OPEN, INVESTIGATING, ESCALATED, RESOLVED, CLOSED
  priority String // LOW, MEDIUM, HIGH, CRITICAL
  type     String // PACKAGE_DAMAGED, NOT_DELIVERED, OVERCHARGING, etc.

  description String
  photos      String[] @default([])
  gpsLog      Boolean  @default(false)

  resolutionNotes String?
  refundAmount    Float?
  resolvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courier_disputes")
}

model PromoCode {
  id            String    @id @default(uuid())
  code          String    @unique // e.g. "FIRSTDEL20"
  type          String // "% OFF", "FREE DELIVERY", "FIXED $", "CORPORATE"
  value         Float
  description   String?
  target        String? // "NEW USERS", "ALL", "REFERRAL", "CORPORATE"
  usageLimit    Int?
  currentUsage  Int       @default(0)
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE
  revenueImpact Float? // calculated
  redemptions   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("promo_codes")
}

model CourierAlert {
  id       String  @id @default(uuid())
  title    String
  message  String
  type     String // CRITICAL, WARNING, INFO
  status   String // NEW, ACKNOWLEDGED, ACTIONED, DISMISSED
  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courier_alerts")
}

model Conversation {
  id     String @id @default(uuid())
  tripId String @unique
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  riderId  String
  driverId String

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId   String
  senderType String // "RIDER" or "DRIVER"

  content      String?
  voiceNoteUrl String? // S3 URL for voice note
  type         String  @default("TEXT") // TEXT, VOICE_NOTE, IMAGE, LOCATION

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("messages")
}
