// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum UserRole {
  RIDER
  DRIVER
  CAR_OWNER
  ADMIN
}

model User {
  id         String   @id @default(uuid())
  email      String?  @unique
  phone      String?  @unique
  firstName  String
  lastName   String
  password   String?
  provider   String? // "local" | "google" | "facebook"
  providerId String?  @unique
  verified   Boolean  @default(false)
  role       UserRole @default(RIDER)
  profilePicture    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  fcmToken          String?

  language              String?   @default("en")    // e.g. "en", "fr", "yo"
  pushNotifications     Boolean   @default(true)
  navigationPreference  String?   @default("google") // e.g. "google", "waze", "apple"

  refreshTokens     RefreshToken[]
  verificationCodes VerificationCode[]

  driver         Driver?
  rider          Rider?
  carOwner       CarOwner?
  scheduledRides ScheduledRide[] @relation("RiderScheduledRides")
  trips          Trip[]
  notifications     Notification[]

  @@map("users")
}

model Driver {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankName            String?
  accountNumber       String?
  accountName         String?

  vehicleModel      String?
  vehiclePlate      String?   @unique
  vehicleColor      String?
  vehicleYear       Int?
  licenseNumber     String?   @unique
  licenseExpiry     DateTime?
  licenseUrl          String?   // S3 URL
  vehicleRegUrl       String?   // S3 URL
  insuranceUrl        String?   // S3 URL
  documentsVerified Boolean   @default(false)

  status           String    @default("pending") // pending, approved, rejected, suspended
  rejectionReason  String?
  approvedAt       DateTime?
  suspendedAt      DateTime?
  suspensionReason String?

  rating     Float @default(0.0)
  totalTrips Int   @default(0)
  totalEarnings       Float     @default(0.0)

  isOnline            Boolean   @default(false)
  currentLocation     Json?     
  lastLocationUpdate  DateTime? @db.Timestamp

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scheduledRides ScheduledRide[]
  trips          Trip[]

  carRentalBookings   CarRentalBooking[]

  @@map("drivers")
}

model CarRental {
  id            String   @id @default(uuid())
  ownerId       String
  owner         CarOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  vehicleModel  String
  vehiclePlate  String   @unique
  vehicleColor  String?
  vehicleYear   Int?
  vehicleType   String   
  pricePerDay   Float
  available     Boolean  @default(true)
  description   String?
  images        String[] 

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings      CarRentalBooking[]

  @@map("car_rentals")
}

model CarRentalBooking {
  id          String    @id @default(uuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  carId       String
  car         CarRental @relation(fields: [carId], references: [id], onDelete: Cascade)

  startDate   DateTime
  endDate     DateTime
  totalPrice  Float?
  status      String    @default("pending") // pending, confirmed, active, completed, cancelled

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("car_rental_bookings")
}

model Rider {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalRides Int   @default(0)
  rating     Float @default(0.0)
  totalSpent Float @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("riders")
}

model CarOwner {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String?
  status          String    @default("pending")
  approvedAt      DateTime?
  rejectionReason String?

  totalCars     Int   @default(0)
  totalEarnings Float @default(0.0)

  carRentals        CarRental[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("car_owners")
}

model ScheduledRide {
  id      String @id @default(uuid())
  riderId String
  rider   User   @relation("RiderScheduledRides", fields: [riderId], references: [id])

  pickupLocation  Json
  dropoffLocation Json
  scheduledTime   DateTime
  vehicleType     String?
  estimatedPrice  Float?
  status          String   @default("pending")
  driverId        String?
  driver          Driver?  @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scheduled_rides")
}

model Trip {
  id        String   @id @default(uuid())
  riderId   String
  driverId  String?
  pickupLocation  Json     // { lat: number, lng: number, address?: string }
  dropoffLocation Json    // { lat: number, lng: number, address?: string }
  status    String // ongoing, completed, cancelled
  revenue   Float?
  rating    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rider  User    @relation(fields: [riderId], references: [id])
  driver Driver? @relation(fields: [driverId], references: [id])

  @@map("trips")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  message   String
  type      String?  // e.g. "ride_request", "payment", "system"
  read      Boolean  @default(false)
  data      Json?    // optional payload, e.g. { rideId: "..." }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      String // "signup" | "reset-password"
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_codes")
}
